<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartPoliceApp"
        android:usesCleartextTraffic="true">
        
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity" />
        <activity android:name=".ui.dashboard.OfficerDashboardActivity" />
        <activity android:name=".ui.supervisory.SupervisoryDashboardActivity" />
        <activity android:name=".ui.complaint.ComplaintRegistrationActivity" />
        <activity android:name=".ui.complaint.ComplaintListActivity" />
        <activity android:name=".ui.evidence.EvidenceUploadActivity" />
        <activity android:name=".ui.complaint.ComplaintSearchActivity" />
        <activity android:name=".ui.complaint.ComplaintDetailActivity" />
        <activity android:name=".ui.complaint.InvestigationTrackerActivity" />
        <activity android:name=".ui.complaint.WitnessStatementActivity" />
        <activity android:name=".ui.complaint.DocumentGeneratorActivity" />
        <activity android:name=".ui.supervisory.SupervisoryWorkloadActivity" />
        <activity android:name=".ui.dashboard.HotspotMapActivity" />
        <activity android:name=".ui.dashboard.ProfileActivity" />
        <activity android:name=".ui.legal.LegalAssistanceActivity" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_API_KEY_HERE" />

    </application>

</manifest>
